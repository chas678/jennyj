<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Console appender for tests -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root logger - WARN level to reduce test noise -->
    <root level="WARN">
        <appender-ref ref="STDOUT" />
    </root>

    <!-- Keep Timefold quiet during tests unless there are errors -->
    <logger name="ai.timefold.solver" level="ERROR" />
</configuration>
