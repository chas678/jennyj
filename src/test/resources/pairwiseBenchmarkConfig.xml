<?xml version="1.0" encoding="UTF-8"?>
<plannerBenchmark>
  <benchmarkDirectory>target/benchmark-results</benchmarkDirectory>
  <warmUpSecondsSpentLimit>0</warmUpSecondsSpentLimit>

  <!-- Incremental Score Calculator - 30 seconds -->
  <solverBenchmark>
    <name>Incremental-30s</name>
    <solver>
      <environmentMode>NO_ASSERT</environmentMode>
      <solutionClass>com.pobox.chas66.PairwiseSolution</solutionClass>
      <entityClass>com.pobox.chas66.TestRun</entityClass>
      <entityClass>com.pobox.chas66.FeatureAssignment</entityClass>

      <scoreDirectorFactory>
        <incrementalScoreCalculatorClass>com.pobox.chas66.PairwiseIncrementalScoreCalculator</incrementalScoreCalculatorClass>
      </scoreDirectorFactory>

      <termination>
        <secondsSpentLimit>30</secondsSpentLimit>
      </termination>

      <localSearch>
        <acceptor>
          <entityTabuSize>40</entityTabuSize>
          <lateAcceptanceSize>300</lateAcceptanceSize>
        </acceptor>
        <moveSelector>
          <unionMoveSelector>
            <changeMoveSelector>
              <entitySelector>
                <entityClass>com.pobox.chas66.FeatureAssignment</entityClass>
              </entitySelector>
            </changeMoveSelector>
            <changeMoveSelector/>
            <swapMoveSelector>
              <entitySelector>
                <entityClass>com.pobox.chas66.FeatureAssignment</entityClass>
              </entitySelector>
            </swapMoveSelector>
          </unionMoveSelector>
        </moveSelector>
      </localSearch>
    </solver>
  </solverBenchmark>

